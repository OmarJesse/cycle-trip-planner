# Copy to `.env` and fill in values.

# Provider selection
LLM_PROVIDER="anthropic"   # anthropic | gemini | mock
LLM_MODEL="claude-3-haiku-20240307"

# Keys (depending on provider)
ANTHROPIC_API_KEY="YOUR_KEY"
GEMINI_API_KEY=""

# Runtime knobs
MAX_TOOL_ROUNDS="6"
MAX_TOKENS="900"
INCLUDE_STRUCTURED_PLAN="true"

# CORS
CORS_ALLOW_ORIGINS='["*"]'

